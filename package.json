{
  "name": "orca",
  "version": "0.2.0",
  "description": "Declarative build orchestrator for Claude Code agents",
  "type": "module",
  "main": "src/cli.ts",
  "bin": {
    "orca": "src/cli.ts"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "bun build src/cli.ts --compile --outfile bin/orca",
    "build:linux-x64": "bun build src/cli.ts --compile --target=bun-linux-x64 --outfile bin/orca-linux-x64",
    "build:linux-arm64": "bun build src/cli.ts --compile --target=bun-linux-arm64 --outfile bin/orca-linux-arm64",
    "build:mac-x64": "bun build src/cli.ts --compile --target=bun-darwin-x64 --outfile bin/orca-darwin-x64",
    "build:mac-arm64": "bun build src/cli.ts --compile --target=bun-darwin-arm64 --outfile bin/orca-darwin-arm64",
    "build:all": "bun run build:linux-x64 && bun run build:linux-arm64 && bun run build:mac-x64 && bun run build:mac-arm64",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "bunx biome check src/",
    "validate-schema": "bun run src/config/validate.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "js-yaml": "^4.1.0",
    "ajv": "^8.17.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/js-yaml": "^4.0.9",
    "typescript": "^5.7.0"
  }
}
