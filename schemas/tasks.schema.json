{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://onezero.computer/schemas/tasks.yaml",
  "title": "Orca Tasks File",
  "description": "External task definitions referenced by project.orca.yaml via tasks.file.",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id"],
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_-]*$",
        "description": "Unique task identifier."
      },
      "title": { "type": "string" },
      "tags": {
        "type": "array",
        "items": { "type": "string" }
      },
      "depends_on": {
        "type": "array",
        "items": { "type": "string" }
      },
      "eval": {
        "type": "object",
        "properties": {
          "command": { "type": "string" },
          "parser": { "type": "string", "enum": ["cargo_test", "pytest", "json", "exit_code"] },
          "timeout": { "type": "integer", "minimum": 1 },
          "results_file": { "type": "string" }
        },
        "additionalProperties": false
      },
      "budget": {
        "type": "object",
        "properties": {
          "max_iterations": { "type": "integer", "minimum": 1 },
          "max_cost": { "type": "number", "minimum": 0 }
        },
        "additionalProperties": false
      },
      "stages": {
        "type": "object",
        "additionalProperties": {
          "type": "object",
          "properties": {
            "max_turns": { "type": "integer", "minimum": 1 },
            "toolset": { "type": "string", "enum": ["read_only", "all", "code", "bash"] },
            "model": { "type": "string" },
            "timeout": { "type": "integer", "minimum": 1 }
          },
          "additionalProperties": false
        }
      },
      "variables": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "additionalProperties": false
  }
}
